{
  "name": "react-admin-nestjs-example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "up": "yarn npm-check-updates --workspaces --interactive",
    "start": "yarn workspace postgres start && yarn workspaces foreach --all --parallel --verbose --exclude 'postgres:.' run start",
    "up-yarn": "yarn set version latest"
  },
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "npm-check-updates": "^21.0.3"
  }
}
